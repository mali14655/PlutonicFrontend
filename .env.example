# Backend API (required on Vercel — your deployed Express/MongoDB server URL, no trailing slash)
# Example: https://plutonic-api.onrender.com
VITE_API_URL=

# Firebase (admin push notifications — client-side public keys)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Web Push public key: Firebase Console → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=
